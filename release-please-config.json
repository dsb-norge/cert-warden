{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "packages": {
    ".": {
      "package-name": "cert-warden",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        { "type": "generic", "path": ".github/workflows/reusable-warden.yml" },
        { "type": "generic", "path": ".github/workflows/reusable-monitor.yml" },
        { "type": "generic", "path": ".github/workflows/reusable-sweeper.yml" },
        { "type": "generic", "path": ".github/workflows/preview-consume.yml" }
      ]
    }
  }
}
